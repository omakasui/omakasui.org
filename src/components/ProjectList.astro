---
import type { CollectionEntry } from "astro:content";

const { projects } = Astro.props;
type Project = CollectionEntry<"projects">;
---

{
  projects.length > 0 &&
    projects.map((project: Project) => (
      <div class="border-border bg-surface hover:border-primary mb-8 rounded-sm border p-5 transition-colors duration-300 ease-in-out sm:p-8">
        <h3>
          <span class="text-foreground-muted mr-1 select-none">&gt;</span>
          {project.data.siteUrl ? (
            <a
              href={project.data.siteUrl}
              target="_blank"
              title={`Visit ${project.data.name} website`}
              rel="noopener"
              class="text-primary text-xl font-semibold hover:underline sm:text-[1.5rem]"
            >
              {project.data.name}
            </a>
          ) : (
            <span class="text-primary text-xl font-semibold sm:text-[1.5rem]">
              {project.data.name}
            </span>
          )}
        </h3>
        <p
          class="text-foreground-secondary mb-6"
          set:html={project.data.description}
        />
        <div
          class="border-border-light bg-background-secondary relative mx-0 my-6 flex items-center gap-2 rounded-sm border p-3 sm:gap-4 sm:p-4"
          role="group"
          aria-label={`Installation command for ${project.data.name}`}
        >
          <code
            class="text-primary flex min-w-0 flex-1 items-center overflow-x-auto bg-none text-xs whitespace-nowrap sm:text-[0.9rem]"
            aria-label="Installation command"
            style="scrollbar-width: thin;"
          >
            {project.data.installCommand}
          </code>
          <button
            class="border-border-light bg-surface text-foreground-secondary hover:bg-surface-hover hover:text-foreground-bright ml-auto flex shrink-0 cursor-pointer items-center justify-center rounded border px-3 py-2 text-[0.75rem] transition-colors"
            onclick={`navigator.clipboard.writeText('${project.data.installCommand}')`}
            title="Copy to clipboard"
            aria-label="Copy installation command to clipboard"
          >
            <i class="nf nf-md-content_copy" />
          </button>
        </div>
        {project?.data.sourceUrl || project?.data.manualUrl ? (
          <p class="text-foreground-secondary text-[0.875rem] italic">
            The{" "}
            {project.data.sourceUrl && (
              <a
                href={project.data.sourceUrl}
                target="_blank"
                title={`View ${project.data.name} source code on GitHub`}
                rel="noopener"
              >{`source code`}</a>
            )}{" "}
            {project?.data.sourceUrl && project?.data.manualUrl ? "and" : null}{" "}
            {project.data.manualUrl && (
              <a
                href={project.data.manualUrl}
                target="_blank"
                title={`View ${project.data.name} manual`}
                rel="noopener"
              >
                {`manual`}
              </a>
            )}{" "}
            {project?.data.sourceUrl && project?.data.manualUrl ? "are" : "is"}{" "}
            available.
          </p>
        ) : null}
      </div>
    ))
}
