<script>
  function enhanceMarkdown() {
    const container = document.querySelector(".markdown-content");
    if (!container) return;

    // Heading links for h2
    container.querySelectorAll("h2").forEach((header) => {
      if (header.querySelector(".heading-links")) return;

      const text = header.textContent || "";
      const anchorId = text
        .toLowerCase()
        .replace(/[^a-z0-9\s-]/g, "")
        .replace(/\s+/g, "-")
        .trim();

      header.id = anchorId;

      const link = document.createElement("a");
      link.className = "heading-links";
      link.innerHTML = "<i class='nf nf-md-link_variant'></i>";
      link.setAttribute("aria-label", `Link to ${text}`);
      link.setAttribute("href", `#${anchorId}`);
      link.title = "Copy link to clipboard";

      link.addEventListener("click", (e) => {
        e.preventDefault();
        const url = `${window.location.origin}${window.location.pathname}#${anchorId}`;
        navigator.clipboard.writeText(url).catch(() => {});
      });

      header.appendChild(link);
    });

    // Copy buttons for code blocks
    container.querySelectorAll("pre").forEach((block) => {
      if (block.querySelector(".code-copy-button")) return;

      const codeEl = block.querySelector("code");
      if (!codeEl) return;

      const btn = document.createElement("button");
      btn.className = "code-copy-button";
      btn.innerHTML = '<i class="nf nf-md-content_copy"></i>';
      btn.title = "Copy code to clipboard";
      btn.setAttribute("aria-label", "Copy code to clipboard");

      btn.addEventListener("click", () => {
        const text = codeEl.textContent || "";
        navigator.clipboard
          .writeText(text)
          .then(() => {
            const orig = btn.innerHTML;
            btn.innerHTML = '<i class="nf nf-md-check"></i>';
            btn.style.color = "#4ade80";
            setTimeout(() => {
              btn.innerHTML = orig;
              btn.style.color = "";
            }, 2000);
          })
          .catch(() => {});
      });

      block.appendChild(btn);
    });
  }

  // Runs on initial load AND after every ViewTransition navigation
  document.addEventListener("astro:page-load", enhanceMarkdown);
</script>
