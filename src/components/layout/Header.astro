---
interface Props {
  title?: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<header class="mb-8">
  {title && <h1 class="sr-only">{title}</h1>}
  {
    subtitle && (
      <p class="text-foreground-secondary text-[1.05rem] leading-relaxed">
        {subtitle}
      </p>
    )
  }
</header>
