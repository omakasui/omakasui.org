---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";

const sections = (await getCollection("sections")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Layout>
  <section aria-labelledby="welcome-heading">
    <h1 class="sr-only" id="welcome-heading">Omakasui</h1>
    <p
      class="text-foreground-muted mb-1 font-mono text-xs select-none"
      aria-hidden="true"
    >
      kasui@omakasui:~ $ ls -la
    </p>
    <p class="text-foreground-muted mb-6 font-mono text-xs">
      total {sections.length} &mdash; post-installation scripts for Linux
    </p>
    <ul class="space-y-3" role="list">
      {
        sections.map((s) => (
          <li>
            <a
              href={s.data.href}
              class="group flex items-baseline gap-x-3 no-underline sm:gap-x-4"
            >
              <span
                class="text-foreground-muted hidden shrink-0 font-mono text-xs select-none sm:inline"
                aria-hidden="true"
              >
                drwxr-xr-x
              </span>
              <span class="text-primary group-hover:text-primary-light w-20 shrink-0 font-mono text-sm font-semibold transition-colors duration-200 sm:w-28">
                {s.data.name}
              </span>
              <span class="text-foreground-secondary truncate font-mono text-xs">
                {s.data.desc}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
