---
import { getCollection } from "astro:content";

import Layout from "@/layouts/Layout.astro";
import ProjectList from "@/components/ProjectList.astro";
import HiddensToggle from "@/components/HiddensToggle.astro";

const projects = await getCollection("projects");
const activeProjects = projects.filter((p) => !p.data.hidden);
const hiddenProjects = projects.filter((p) => p.data.hidden);
---

<Layout title="Projects">
  <section aria-labelledby="projects-heading">
    <h1 class="sr-only" id="projects-heading">Projects</h1>
    <p
      class="text-foreground-muted mb-6 font-mono text-xs select-none"
      aria-hidden="true"
    >
      $ ls -la projects/
    </p>
    <ProjectList projects={activeProjects} />
    {
      hiddenProjects.length > 0 && (
        <HiddensToggle count={hiddenProjects.length}>
          <ProjectList projects={hiddenProjects} />
        </HiddensToggle>
      )
    }
  </section>
</Layout>
