---
import { getCollection } from "astro:content";

import Layout from "@/layouts/Layout.astro";
import ThemesList from "@/components/ThemesList.astro";

const themes = (await getCollection("themes")).sort((a, b) =>
  a.data.name.localeCompare(b.data.name),
);
---

<Layout title="Themes">
  <section aria-labelledby="themes-heading">
    <h2
      class="text-foreground-muted mb-3 font-mono text-xs font-normal"
      id="themes-heading"
    >
      $ ls themes/
    </h2>
    {
      themes.length === 0 ? (
        <p class="text-foreground-muted italic">No themes available yet.</p>
      ) : (
        <ThemesList themes={themes} />
      )
    }
  </section>
</Layout>
